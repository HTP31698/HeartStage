  m_text: "\u2460 \uB9E4\uC77C \uB77C\uC774\uD2B8 \uC2A4\uD2F1\uC744 \uC0AC\uC6A9\uD574
    \uC544\uC774\uB3CC \uBA64\uBC84\uC758 \uD76C\uB9DD \n\uC5D0\uB108\uC9C0\uB97C
    \uC62C\uB9B4 \uC218 \uC788\uC5B4\uC694.\r\n\r\n\u2461 \uB0B4 \uC544\uC774\uB3CC
    \uBA64\uBC84\uB294 \uD558\uB8E8\uC5D0 \uCD5C\uB300 5\uBA85\uAE4C\uC9C0 \uC751\uC6D0\uD560
    \n\uC218 \uC788\uC5B4\uC694.\r\n\r\n\u2462 \uCE5C\uAD6C \uC219\uC18C\uC5D0 \uB180\uB7EC\uAC00\uC11C
    \uCE5C\uAD6C\uC758 \uC544\uC774\uB3CC \uBA64\uBC84\uB3C4 \n\uD558\uB8E8\uC5D0
    \uCD5C\uB300 3\uBA85\uAE4C\uC9C0 \uC751\uC6D0\uD560 \uC218 \uC788\uC5B4\uC694.\r\n\r\n\u2463
    \uD76C\uB9DD \uC5D0\uB108\uC9C0\uAC00 20 / 50 / 100\uC774 \uB418\uBA74 \uB2E8\uACC4\uBCC4\uB85C
    \n\uD2B9\uBCC4\uD55C \uC120\uBB3C\uC744 \uBC1B\uC744 \uC218 \uC788\uC5B4\uC694.\r\n"
