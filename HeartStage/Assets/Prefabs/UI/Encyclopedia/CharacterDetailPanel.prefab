    - target: {fileID: 1965771595364356813, guid: 71932ae9a4ad449bd835b73721606d70, type: 3}
      propertyPath: m_text
      value: "\uD0A4 : 161cm\r\n\uB098\uC774 :  \uB9CC 18\uC138\r\n\uC131\uACA9 :
        \uB9E4\uC0AC\uC5D0 \uAE0D\uC815\uC801\uC774\uACE0 \uD30C\uC774\uD305 \uB118\uCE68.
        \uC678\uD5A5\uC801, \uC0AC\uAD50\uC801, \uC6A9\uAC10\uD568\r\n\uD558\uB098\uB294
        \uC5B4\uB9B4 \uB54C\uBD80\uD130 \uC544\uC774\uB3CC\uC744 \uAFC8\uAFB8\uBA70
        \uC218\uB9CE\uC740 \uC2DC\uD589\uCC29\uC624\uB97C \uACAA\uC5C8\uC9C0\uB9CC,
        \uD3EC\uAE30\uD558\uC9C0 \uC54A\uACE0 \uBB34\uB300\uB97C \uD5A5\uD574 \uAFB8\uC900\uD788
        \uB178\uB825\uD588\uB2E4.\r\n\uADF8\uB7EC\uB358 \uC5B4\uB290 \uB0A0 \uD63C\uC790
        \uB098\uC120 \uAE38\uAC70\uB9AC \uBC84\uC2A4\uD0B9 \uACF5\uC5F0\uC5D0\uC11C
        \uCC9C\uC0AC\uC5D0\uAC8C \uBA85\uD568\uC744 \uAC74\uB124 \uBC1B\uACE0 \uC9C1\uC811
        \uC2A4\uCE74\uC6B0\uD2B8\uB41C\uB2E4. \uB118\uCE58\uB294 \uAFC8 \uC5D0\uB108\uC9C0\uC640
        \uAE0D\uC815\uC801\uC778 \uAC10\uC815 \uB355\uBD84\uC5D0 \uCC9C\uC0AC\uC758
        \uCCAB \uBC88\uC9F8 \uCE90\uC2A4\uD305 \uBA64\uBC84\uAC00 \uB418\uC5C8\uB2E4."
      objectReference: {fileID: 0}
